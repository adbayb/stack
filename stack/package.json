{
	"name": "@adbayb/stack",
	"version": "2.40.0",
	"description": "My opinionated JavaScript-based toolchain",
	"keywords": [
		"development",
		"scripts",
		"stack",
		"toolchain"
	],
	"license": "MIT",
	"author": {
		"name": "Ayoub Adib",
		"email": "adbayb@gmail.com",
		"url": "https://twitter.com/adbayb"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/adbayb/stack.git",
		"directory": "applications/stack"
	},
	"bin": {
		"stack": "./bin/index.js"
	},
	"files": [
		"bin",
		"configs",
		"dist",
		"templates"
	],
	"type": "module",
	"exports": {
		".": {
			"source": "./src/index.ts",
			"default": "./dist/index.js"
		},
		"./oxfmt": {
			"source": "./configs/oxfmt/index.ts",
			"types": "./dist/configs/oxfmt.d.ts",
			"default": "./dist/configs/oxfmt.js"
		},
		"./oxlint": {
			"source": "./configs/oxlint/index.ts",
			"types": "./dist/configs/oxlint.d.ts",
			"default": "./dist/configs/oxlint.js"
		},
		"./typescript": "./configs/typescript/index.json"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org"
	},
	"scripts": {
		"build": "quickbundle build",
		"prepublishOnly": "pnpm build",
		"prestart": "pnpm build",
		"start": "./bin/index.js",
		"watch": "quickbundle watch"
	},
	"dependencies": {
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@commitlint/cli": "^21.2.1",
		"@commitlint/config-conventional": "^21.2.0",
		"@e18e/eslint-plugin": "^0.5.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"eslint-plugin-perfectionist": "^5.10.0",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"oxlint-tsgolint": "^0.24.0",
		"termost": "^1.9.1",
		"turbo": "^2.10.4",
		"typescript": "^6.0.3"
	},
	"devDependencies": {
		"@types/node": "24.13.3",
		"quickbundle": "3.0.0"
	}
}
