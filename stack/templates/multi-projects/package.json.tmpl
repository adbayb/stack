{
	"name": "root",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "stack build",
		"check": "stack check",
		"clean": "stack clean",
		"fix": "stack fix",
		"install": "stack install",
		"release:log": "stack release --log",
		"release:publish": "stack release --publish",
		"release:version": "stack release --tag",
		"start": "stack start",
		"test": "stack test",
		"watch": "stack watch"
	},
	"prettier": "@adbayb/stack/prettier",
	"packageManager": "pnpm@{{npmVersion}}",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "{{npmVersion}}",
			"onFail": "download"
		},
		"runtime": {
			"name": "node",
			"version": ">=24.0.0",
			"onFail": "error"
		}
	}
}
